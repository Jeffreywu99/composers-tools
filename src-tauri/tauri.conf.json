{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-tauri/main/.schemas/config.schema.json",
  "productName": "Composers Tools",
  "version": "0.2.0",
  "identifier": "com.composers-tools.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "作曲工具",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
